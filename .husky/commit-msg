commit_msg=$(cat "$1")

# Format: type(scope): message
# Example: feat(Login): add JWT token validation
valid_commit_regex="^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)\([^)]+\): .+"

if ! echo "$commit_msg" | grep -qE "$valid_commit_regex"; then
    echo ""
    echo "  Invalid commit message: '$commit_msg'"
    echo ""
    echo "  Required format : type(scope): message"
    echo "  Example         : feat(Login): add JWT token validation"
    echo "  Example         : fix(Upload): resolve file size limit issue"
    echo ""
    echo "  Types   : feat | fix | docs | style | refactor | test | chore | perf | ci | build | revert"
    echo "  Scope   : optional, e.g. feat(Login): ..."
    echo ""
    exit 1
fi
